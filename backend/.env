# --- Database ---
DATABASE_URL=postgresql://enterprisehub:enterprisehub@localhost:5432/enterprisehub

# --- Security ---
SECRET_KEY=change-this-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- Storage (MinIO / S3-compatible) ---
STORAGE_BACKEND=local          # local | s3
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=enterprisehub-files
S3_REGION=us-east-1

# Only used when STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage/uploads

# --- App ---
APP_NAME=EnterpriseHub AI
CORS_ORIGINS=http://localhost:3000
